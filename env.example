# --- YouTube playback ---
# Copy this file to .env and paste your YouTube Data API v3 key below.
# The app works fully without this — it falls back to a local mock catalog.
# Get a key: https://console.cloud.google.com/apis/credentials (enable "YouTube Data API v3")
VITE_YOUTUBE_API_KEY=

# --- Accounts + cross-device device sync (Firebase) ---
# Create a free project at https://console.firebase.google.com
# 1. Add a Web App to the project, copy the config values below.
# 2. Authentication -> Sign-in method -> enable "Google".
# 3. Firestore Database -> Create database (start in test mode is fine to try it out).
# The app works fully without these — sign-in is simply hidden and devices
# stay local to the current browser session.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
